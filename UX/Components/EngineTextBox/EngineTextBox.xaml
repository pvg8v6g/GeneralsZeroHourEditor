<UserControl x:Class="GeneralsZeroHourEditor.UX.Components.EngineTextBox.EngineTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <TextBox Text="{x:Bind Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
           Header="{x:Bind Header, Mode=OneWay}"
           PlaceholderText="{x:Bind PlaceholderText, Mode=OneWay}"
           MaxLength="{x:Bind MaxLength, Mode=OneWay}"
           InputScope="{x:Bind InputType, Converter={StaticResource InputTypeToInputScopeConverter}, Mode=OneWay}"
           AcceptsReturn="{x:Bind AcceptsReturn, Mode=OneWay}"
           TextWrapping="{x:Bind TextWrapping, Mode=OneWay}"
           ToolTipService.ToolTip="{x:Bind Tooltip}"
           TextChanging="OnTextChanging" />
</UserControl>
