<Page x:Class="GeneralsZeroHourEditor.UX.Views.HomePage.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:behaviors="using:GeneralsZeroHourEditor.Behaviors"
      mc:Ignorable="d"
      behaviors:LoadedBehavior.LoadedCommand="{x:Bind ViewModel.LoadedCommand}">
  <Grid Background="{StaticResource DarkGreyBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Frame x:Name="TopBarFrame" Background="Transparent" />
    <Frame Grid.Row="1" x:Name="ActiveFrame" Background="Transparent" />
  </Grid>
</Page>
