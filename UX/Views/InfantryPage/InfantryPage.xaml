<Page x:Class="GeneralsZeroHourEditor.UX.Views.InfantryPage.InfantryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:behaviors="using:GeneralsZeroHourEditor.Behaviors"
      xmlns:models="using:GeneralsZeroHourEditor.Models"
      xmlns:enginePanel="using:GeneralsZeroHourEditor.UX.Components.EnginePanel"
      xmlns:engineTextBox="using:GeneralsZeroHourEditor.UX.Components.EngineTextBox"
      mc:Ignorable="d"
      behaviors:LoadedBehavior.LoadedCommand="{x:Bind ViewModel.LoadedCommand}">
  <Grid ColumnSpacing="10" Padding="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="350" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left: Infantry list -->
    <Border Grid.Column="0"
            Background="{StaticResource SecondaryBrush}"
            Padding="8"
            CornerRadius="6">
      <Grid RowSpacing="6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="Infantry"
                   FontWeight="Bold"
                   Foreground="{StaticResource WhiteBrush}" />
        <TreeView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Model.GameObjectGroups, Mode=OneWay}"
                  behaviors:TreeViewBehavior.ItemInvokedCommand="{x:Bind ViewModel.ItemInvokedCommand}">
          <TreeView.ItemTemplate>
            <DataTemplate x:DataType="models:GameObjectNodeModel">
              <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}">
                <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
              </TreeViewItem>
            </DataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
      </Grid>
    </Border>

    <ScrollViewer Grid.Column="1"
                  VerticalScrollBarVisibility="Auto"
                  Padding="0 0 18 0">
      <StackPanel Spacing="10">
        <!-- 1) Object metadata -->
        <enginePanel:EnginePanel Title="Object Metadata"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <Grid RowSpacing="10"
                ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Define rows to prevent content stacking/overlap -->
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />  <!-- Row 0: Name / Side -->
              <RowDefinition Height="Auto" />  <!-- Row 1: EditorSorting / CommandSet -->
              <RowDefinition Height="Auto" />  <!-- Row 2: SelectPortrait / ButtonImage -->
              <RowDefinition Height="Auto" />  <!-- Row 3: BuildCost / BuildTime -->
              <RowDefinition Height="Auto" />  <!-- Row 4: BuildCompletion -->
              <RowDefinition Height="Auto" />  <!-- Row 5: Lists (Prerequisites / KindOf) -->
            </Grid.RowDefinitions>

            <!-- Identity & UI Art -->
            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="0"
                                         Header="Name"
                                         Text="{x:Bind ViewModel.Model.Detail.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="0"
                                         Header="Side"
                                         Text="{x:Bind ViewModel.Model.Detail.Side, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="1"
                                         Header="EditorSorting"
                                         Text="{x:Bind ViewModel.Model.Detail.EditorSorting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="1"
                                         Header="CommandSet"
                                         Text="{x:Bind ViewModel.Model.Detail.CommandSet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="2"
                                         Header="SelectPortrait"
                                         Text="{x:Bind ViewModel.Model.Detail.SelectPortrait, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="2"
                                         Header="ButtonImage"
                                         Text="{x:Bind ViewModel.Model.Detail.ButtonImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Production -->
            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="3"
                                         Header="BuildCost"
                                         InputType="Integer"
                                         Text="{x:Bind ViewModel.Model.Detail.BuildCost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="3"
                                         Header="BuildTime"
                                         InputType="Double"
                                         Text="{x:Bind ViewModel.Model.Detail.BuildTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="4"
                                         Header="BuildCompletion"
                                         Text="{x:Bind ViewModel.Model.Detail.BuildCompletion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Prerequisites (typed list: Object/Science) -->
            <StackPanel Grid.Column="0"
                        Grid.Row="5"
                        HorizontalAlignment="Stretch"
                        Spacing="4">
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Prerequisites" FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Content="Add"
                        Command="{x:Bind ViewModel.AddPrerequisiteCommand, Mode=OneWay}"
                        ToolTipService.ToolTip="Add prerequisite row" />
              </Grid>

              <ListView x:Name="PrereqList"
                        Tag="{x:Bind ViewModel, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.Model.Detail.PrereqEntries, Mode=OneWay}">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="models:PrerequisiteEntryModel">
                    <Grid ColumnSpacing="8"
                          Padding="0 10 0 10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <!-- Type picker -->
                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <ComboBox Grid.Column="0"
                                MinWidth="200"
                                MaxWidth="200"
                                HorizontalContentAlignment="Stretch"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ItemsSource="{Binding ElementName=PrereqList, Path=Tag.PrereqTypes}"
                                SelectedItem="{x:Bind Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>

                      <!-- Value picker (items depend on Type) -->
                      <ComboBox Grid.Column="1"
                                MinWidth="200"
                                MaxWidth="200"
                                HorizontalContentAlignment="Stretch"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ItemsSource="{x:Bind Items, Mode=OneWay}"
                                SelectedItem="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>

                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <Button Grid.Column="2"
                              ToolTipService.ToolTip="Remove"
                              AutomationProperties.Name="Remove"
                              Command="{Binding ElementName=PrereqList, Path=Tag.RemovePrerequisiteCommand}"
                              CommandParameter="{Binding}"
                              Background="{StaticResource RedBrush}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>

            <!-- KindOf flags (list) -->
            <StackPanel Grid.Column="1"
                        Grid.Row="5"
                        HorizontalAlignment="Stretch"
                        Spacing="4">
              <TextBlock Text="KindOf" FontWeight="SemiBold" />
              <StackPanel Orientation="Horizontal" Spacing="6">
                <engineTextBox:EngineTextBox x:Name="KindOfInput"
                                             Width="240"
                                             PlaceholderText="Add KindOf flag" />
                <Button Content="Add"
                        Command="{x:Bind ViewModel.AddKindOfCommand, Mode=OneWay}"
                        CommandParameter="{x:Bind KindOfInput.Text, Mode=OneWay}"
                        ToolTipService.ToolTip="Add KindOf flag" />
              </StackPanel>
              <ListView x:Name="KindOfList"
                        Tag="{x:Bind ViewModel, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.Model.Detail.KindOf, Mode=OneWay}"
                        SelectionMode="Single">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Grid ColumnSpacing="6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{x:Bind}"
                                 VerticalAlignment="Center" />
                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <Button Grid.Column="1"
                              ToolTipService.ToolTip="Remove"
                              AutomationProperties.Name="Remove"
                              Command="{Binding ElementName=KindOfList, Path=Tag.RemoveKindOfCommand}"
                              CommandParameter="{Binding}"
                              Background="{StaticResource RedBrush}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>

            <!-- Upgrade Cameos (read-only list for now) -->
            <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="6" Spacing="4">
              <TextBlock Text="Upgrade Cameos" FontWeight="SemiBold" />
              <ListView ItemsSource="{x:Bind ViewModel.Model.Detail.UpgradeCameos, Mode=OneWay}" />
            </StackPanel>
          </Grid>
        </enginePanel:EnginePanel>

        <!-- 2) Visuals (W3D) -->
        <enginePanel:EnginePanel Title="Visuals (W3D)"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="6">
            <TextBlock Text="Draw entries, ConditionStates, TransitionStates, Model/Animations, Weapon bones &amp; FX hooks" />
          </StackPanel>
        </enginePanel:EnginePanel>

        <!-- 3) Armor & Health -->
        <enginePanel:EnginePanel Title="Armor &amp; Health"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="10">
            <!-- Body -->
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <engineTextBox:EngineTextBox Grid.Column="0"
                                           Header="MaxHealth"
                                           InputType="Double"
                                           Text="{x:Bind ViewModel.Model.Detail.MaxHealth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              <engineTextBox:EngineTextBox Grid.Column="1"
                                           Header="InitialHealth"
                                           InputType="Double"
                                           Text="{x:Bind ViewModel.Model.Detail.InitialHealth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!-- Armor Sets -->
            <StackPanel Spacing="6">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Armor Sets" FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Content="Add Set"
                        Command="{x:Bind ViewModel.AddArmorSetCommand}" />
              </Grid>

              <ListView x:Name="ArmorSetsList"
                        Tag="{x:Bind ViewModel, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.Model.Detail.ArmorSets, Mode=OneWay}">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="models:ArmorSetModel">
                    <Grid ColumnSpacing="8"
                          Padding="0 8 0 10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <ComboBox Grid.Column="0"
                                Header="Armor"
                                ItemsSource="{Binding ElementName=ArmorSetsList, Path=Tag.Model.Detail.AvailableArmorTemplates}"
                                SelectedItem="{x:Bind Armor, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                      <engineTextBox:EngineTextBox Grid.Column="0"
                                                   Grid.Row="1"
                                                   Header="Conditions (csv)"
                                                   Text="{x:Bind ConditionsCsv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <Button Grid.Column="1"
                              Grid.Row="0"
                              Grid.RowSpan="2" ToolTipService.ToolTip="Remove"
                              AutomationProperties.Name="Remove"
                              Command="{Binding ElementName=ArmorSetsList, Path=Tag.RemoveArmorSetCommand}"
                              CommandParameter="{Binding}"
                              Background="{StaticResource RedBrush}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>
          </StackPanel>
        </enginePanel:EnginePanel>

        <!-- 4) Weapons -->
        <enginePanel:EnginePanel Title="Weapons"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Weapon Sets" FontWeight="SemiBold" />
              <Button Grid.Column="1"
                      Content="Add Set"
                      Command="{x:Bind ViewModel.AddWeaponSetCommand}" />
            </Grid>

            <ListView x:Name="WeaponSetsList"
                      Tag="{x:Bind ViewModel, Mode=OneWay}"
                      ItemsSource="{x:Bind ViewModel.Model.Detail.WeaponSets, Mode=OneWay}">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:WeaponSetModel">
                  <Grid ColumnSpacing="8"
                        RowSpacing="6"
                        Padding="0 8 0 10">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <ComboBox Grid.Row="0"
                              Grid.Column="0"
                              Header="Primary"
                              ItemsSource="{Binding ElementName=WeaponSetsList, Path=Tag.Model.Detail.AvailableWeaponTemplates}"
                              SelectedItem="{x:Bind Primary, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              Header="Secondary"
                              ItemsSource="{Binding ElementName=WeaponSetsList, Path=Tag.Model.Detail.AvailableWeaponTemplates}"
                              SelectedItem="{x:Bind Secondary, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <ComboBox Grid.Row="0"
                              Grid.Column="2"
                              Header="Tertiary"
                              ItemsSource="{Binding ElementName=WeaponSetsList, Path=Tag.Model.Detail.AvailableWeaponTemplates}"
                              SelectedItem="{x:Bind Tertiary, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <engineTextBox:EngineTextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                 Header="Conditions (csv)"
                                                 Text="{x:Bind ConditionsCsv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <Button Grid.Column="3"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            ToolTipService.ToolTip="Remove"
                            AutomationProperties.Name="Remove"
                            Command="{Binding ElementName=WeaponSetsList, Path=Tag.RemoveWeaponSetCommand}"
                            CommandParameter="{Binding}"
                            Background="{StaticResource RedBrush}">
                      <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                    </Button>

                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </StackPanel>
        </enginePanel:EnginePanel>

        <!-- 5) Behaviors / Modules -->
        <enginePanel:EnginePanel Title="Behaviors / Modules"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="6">
            <TextBlock Text="Add/remove behavior modules (AI, Upgrades, Special Powers, Status, Transport, etc.)" />
          </StackPanel>
        </enginePanel:EnginePanel>

        <!-- 6) Movement -->
        <enginePanel:EnginePanel Title="Movement"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <!-- Locomotors -->
          <StackPanel Spacing="6">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Locomotor Sets" FontWeight="SemiBold" />
              <Button Grid.Column="1"
                      Content="Add Set"
                      Command="{x:Bind ViewModel.AddLocomotorCommand}" />
            </Grid>

            <ListView x:Name="LocomotorList"
                      Tag="{x:Bind ViewModel, Mode=OneWay}"
                      ItemsSource="{x:Bind ViewModel.Model.Detail.LocomotorSets, Mode=OneWay}">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:LocomotorSetModel">
                  <Grid ColumnSpacing="8"
                        RowSpacing="6"
                        Padding="0 8 0 10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <ComboBox Grid.Column="0"
                              Header="Locomotors"
                              ItemsSource="{Binding ElementName=LocomotorList, Path=Tag.Model.Detail.AvailableLocomotors}"
                              SelectedItem="{x:Bind Locomotor, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <engineTextBox:EngineTextBox Grid.Column="0"
                                                 Grid.Row="1"
                                                 Header="Conditions (csv)"
                                                 Text="{x:Bind ConditionsCsv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <Button Grid.Column="1"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            ToolTipService.ToolTip="Remove"
                            AutomationProperties.Name="Remove"
                            Command="{Binding ElementName=LocomotorList, Path=Tag.RemoveLocomotorCommand}"
                            CommandParameter="{Binding}"
                            Background="{StaticResource RedBrush}">
                      <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                    </Button>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </StackPanel>
        </enginePanel:EnginePanel>

        <!-- 7) Vision & Shroud -->
        <enginePanel:EnginePanel Title="Vision &amp; Shroud"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Header="VisionRange"
                                         InputType="Integer"
                                         Text="{x:Bind ViewModel.Model.Detail.VisionRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Header="ShroudClearingRange"
                                         InputType="Integer"
                                         Text="{x:Bind ViewModel.Model.Detail.ShroudClearingRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </Grid>
        </enginePanel:EnginePanel>

        <!-- 8) Geometry & Shadow -->
        <enginePanel:EnginePanel Title="Geometry &amp; Shadow"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <Grid RowSpacing="10" ColumnSpacing="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="0"
                                         Header="Geometry"
                                         Text="{x:Bind ViewModel.Model.Detail.Geometry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="0"
                                         Header="GeometryIsSmall"
                                         Text="{x:Bind ViewModel.Model.Detail.GeometryIsSmall, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="1"
                                         Header="GeometryMajorRadius"
                                         InputType="Double"
                                         Text="{x:Bind ViewModel.Model.Detail.GeometryMajorRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="1"
                                         Header="GeometryMinorRadius"
                                         InputType="Double"
                                         Text="{x:Bind ViewModel.Model.Detail.GeometryMinorRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="2"
                                         Header="GeometryHeight"
                                         InputType="Double"
                                         Text="{x:Bind ViewModel.Model.Detail.GeometryHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="3"
                                         Header="Shadow"
                                         Text="{x:Bind ViewModel.Model.Detail.Shadow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="3"
                                         Header="ShadowTexture"
                                         Text="{x:Bind ViewModel.Model.Detail.ShadowTexture, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="4"
                                         Header="ShadowSizeX"
                                         InputType="Integer"
                                         Text="{x:Bind ViewModel.Model.Detail.ShadowSizeX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="4"
                                         Header="ShadowSizeY"
                                         InputType="Integer"
                                         Text="{x:Bind ViewModel.Model.Detail.ShadowSizeY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </Grid>
        </enginePanel:EnginePanel>

        <!-- 9) Audio & FX -->
        <enginePanel:EnginePanel Title="Audio &amp; FX"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="6">
            <TextBlock Text="Voices, Ambient/Foley, Unit/Weapon/Death FX hooks" />
          </StackPanel>
        </enginePanel:EnginePanel>

        <!-- 10) Flags & Classification -->
        <enginePanel:EnginePanel Title="Flags &amp; Classification"
                                 Visibility="{x:Bind ViewModel.Model.SelectedNode, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="6">
            <TextBlock Text="Use the KindOf list in Object Metadata to edit flags." />
          </StackPanel>
        </enginePanel:EnginePanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
