<Page x:Class="GeneralsZeroHourEditor.UX.Views.InfantryPage.InfantryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:behaviors="using:GeneralsZeroHourEditor.Behaviors"
      xmlns:models="using:GeneralsZeroHourEditor.Models"
      xmlns:enginePanel="using:GeneralsZeroHourEditor.UX.Components.EnginePanel"
      xmlns:engineTextBox="using:GeneralsZeroHourEditor.UX.Components.EngineTextBox"
      xmlns:enumerations="using:GeneralsZeroHourEditor.Enumerations"
      xmlns:ui="using:CommunityToolkit.WinUI"
      mc:Ignorable="d"
      behaviors:LoadedBehavior.LoadedCommand="{x:Bind ViewModel.LoadedCommand}">
  <Grid ColumnSpacing="10" Padding="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="350" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left: Infantry list -->
    <Border Grid.Column="0"
            Background="{StaticResource SecondaryBrush}"
            Padding="8"
            CornerRadius="6">
      <Grid RowSpacing="6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="Infantry"
                   FontWeight="Bold"
                   Foreground="{StaticResource WhiteBrush}" />
        <TreeView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.EntityCollection, Mode=OneWay}"
                  behaviors:TreeViewBehavior.ItemInvokedCommand="{x:Bind ViewModel.SelectedItemChangedCommand}">
          <TreeView.ItemTemplate>
            <DataTemplate x:DataType="models:TreeViewModel">
              <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}">
                <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
              </TreeViewItem>
            </DataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
      </Grid>
    </Border>

    <ScrollViewer Grid.Column="1"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowSpacing="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <enginePanel:EnginePanel Title="Object Metadata"
                                 Visibility="{x:Bind ViewModel.SelectedItem, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <Grid RowSpacing="10"
                ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Define rows to prevent content stacking/overlap -->
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />  <!-- Row 0: Name / Side -->
              <RowDefinition Height="Auto" />  <!-- Row 1: EditorSorting / CommandSet -->
              <RowDefinition Height="Auto" />  <!-- Row 2: SelectPortrait / ButtonImage -->
              <RowDefinition Height="Auto" />  <!-- Row 3: BuildCost / BuildTime -->
              <RowDefinition Height="Auto" />  <!-- Row 4: BuildCompletion -->
              <RowDefinition Height="Auto" />  <!-- Row 5: Lists (Prerequisites / KindOf) -->
            </Grid.RowDefinitions>

            <!-- Identity & UI Art -->
            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="0"
                                         Header="Name"
                                         Text="{x:Bind ViewModel.SelectedItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="0"
                                         Header="Side"
                                         Text="{x:Bind ViewModel.SelectedItem.Side, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="1"
                                         Header="EditorSorting"
                                         Text="{x:Bind ViewModel.SelectedItem.EditorSorting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="1"
                                         Header="CommandSet"
                                         Text="{x:Bind ViewModel.SelectedItem.CommandSet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="2"
                                         Header="SelectPortrait"
                                         Text="{x:Bind ViewModel.SelectedItem.SelectPortrait, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="2"
                                         Header="ButtonImage"
                                         Text="{x:Bind ViewModel.SelectedItem.ButtonImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Production -->
            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="3"
                                         Header="BuildCost"
                                         InputType="Integer"
                                         Text="{x:Bind ViewModel.SelectedItem.BuildCost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1"
                                         Grid.Row="3"
                                         Header="BuildTime"
                                         InputType="Double"
                                         Text="{x:Bind ViewModel.SelectedItem.BuildTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0"
                                         Grid.Row="4"
                                         Header="BuildCompletion"
                                         Text="{x:Bind ViewModel.SelectedItem.BuildCompletion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Prerequisites (typed list: Object/Science) -->
            <StackPanel Grid.Column="0"
                        Grid.Row="5"
                        HorizontalAlignment="Stretch"
                        Spacing="4">
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Prerequisites" FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Content="Add"
                        Command="{x:Bind ViewModel.AddPrerequisiteCommand, Mode=OneWay}"
                        ToolTipService.ToolTip="Add prerequisite row" />
              </Grid>

              <ListView x:Name="PrereqList"
                        Tag="{x:Bind ViewModel, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.SelectedItem.PrereqEntries, Mode=OneWay}">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="models:PrerequisiteSetModel">
                    <Grid ColumnSpacing="8"
                          Padding="0 10 0 10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <!-- Type picker -->
                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <ComboBox Grid.Column="0"
                                MinWidth="200"
                                MaxWidth="200"
                                HorizontalContentAlignment="Stretch"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ItemsSource="{ui:EnumValues Type=enumerations:PrerequisiteType}"
                                SelectedItem="{x:Bind PrerequisiteType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                      <ComboBox Grid.Column="1"
                                MinWidth="250"
                                MaxWidth="250"
                                HorizontalContentAlignment="Stretch"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ItemsSource="{Binding PrerequisiteChoices, Mode=OneWay}"
                                SelectedItem="{x:Bind Prerequisite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <Button Grid.Column="2"
                              ToolTipService.ToolTip="Remove"
                              AutomationProperties.Name="Remove"
                              Command="{Binding ElementName=PrereqList, Path=Tag.RemovePrerequisiteCommand}"
                              CommandParameter="{Binding}"
                              Background="{StaticResource RedBrush}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>

            <!-- KindOf flags (list) -->
            <StackPanel Grid.Column="1"
                        Grid.Row="5"
                        HorizontalAlignment="Stretch"
                        Spacing="4">
              <Grid HorizontalAlignment="Stretch"
                    ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          x:Name="KindOfInput"
                          Header="KindOf"
                          MinWidth="200"
                          MaxWidth="200"
                          VerticalAlignment="Bottom"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ItemsSource="{ui:EnumValues Type=enumerations:KindOf}" />

                <Button Grid.Column="2"
                        Content="Add"
                        Command="{x:Bind ViewModel.AddKindOfCommand, Mode=OneWay}"
                        CommandParameter="{x:Bind KindOfInput.SelectedItem, Mode=OneWay}"
                        VerticalAlignment="Bottom"
                        ToolTipService.ToolTip="Add KindOf flag" />
              </Grid>
              <ListView x:Name="KindOfList"
                        Tag="{x:Bind ViewModel, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.SelectedItem.KindOf, Mode=OneWay}"
                        SelectionMode="Single">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="enumerations:KindOf">
                    <Grid ColumnSpacing="6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{x:Bind}"
                                 VerticalAlignment="Center" />
                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <Button Grid.Column="1"
                              ToolTipService.ToolTip="Remove"
                              AutomationProperties.Name="Remove"
                              Command="{Binding ElementName=KindOfList, Path=Tag.RemoveKindOfCommand}"
                              CommandParameter="{Binding}"
                              Background="{StaticResource RedBrush}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>

            <!-- Upgrade Cameos (read-only list for now) -->
            <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="6" Spacing="4">
              <TextBlock Text="Upgrade Cameos" FontWeight="SemiBold" />
              <ListView ItemsSource="{x:Bind ViewModel.SelectedItem.UpgradeCameos, Mode=OneWay}" />
            </StackPanel>
          </Grid>
        </enginePanel:EnginePanel>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
