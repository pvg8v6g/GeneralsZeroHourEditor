<Page x:Class="GeneralsZeroHourEditor.UX.Views.InfantryPage.InfantryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:behaviors="using:GeneralsZeroHourEditor.Behaviors"
      xmlns:models="using:GeneralsZeroHourEditor.Models"
      xmlns:enginePanel="using:GeneralsZeroHourEditor.UX.Components.EnginePanel"
      xmlns:engineTextBox="using:GeneralsZeroHourEditor.UX.Components.EngineTextBox"
      xmlns:enumerations="using:GeneralsZeroHourEditor.Enumerations"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:weaponSet="using:GeneralsZeroHourEditor.Models.WeaponSet"
      mc:Ignorable="d"
      behaviors:LoadedBehavior.LoadedCommand="{x:Bind ViewModel.LoadedCommand}">
  <Grid ColumnSpacing="10" Padding="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="350" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left: Infantry list -->
    <Border Grid.Column="0"
            Background="{StaticResource SecondaryBrush}"
            Padding="8"
            CornerRadius="6">
      <Grid RowSpacing="6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="Infantry"
                   FontWeight="Bold"
                   Foreground="{StaticResource WhiteBrush}" />
        <TreeView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.EntityCollection, Mode=OneWay}"
                  behaviors:TreeViewBehavior.ItemInvokedCommand="{x:Bind ViewModel.SelectedItemChangedCommand}">
          <TreeView.ItemTemplate>
            <DataTemplate x:DataType="models:TreeViewModel">
              <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}">
                <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
              </TreeViewItem>
            </DataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
      </Grid>
    </Border>

    <ScrollViewer Grid.Column="1"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowSpacing="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1) Metadata -->
        <enginePanel:EnginePanel Grid.Row="0"
                                 Title="Object Metadata"
                                 Visibility="{x:Bind ViewModel.SelectedItem, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <Grid RowSpacing="15">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid RowSpacing="10"
                  ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <!-- Define rows to prevent content stacking/overlap -->
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Row 0: Name / Side -->
                <RowDefinition Height="Auto" />  <!-- Row 1: EditorSorting / CommandSet -->
                <RowDefinition Height="Auto" />  <!-- Row 2: SelectPortrait / ButtonImage -->
                <RowDefinition Height="Auto" />  <!-- Row 3: BuildCost / BuildTime -->
                <RowDefinition Height="Auto" />  <!-- Row 4: BuildCompletion -->
              </Grid.RowDefinitions>

              <!-- Identity & UI Art -->
              <engineTextBox:EngineTextBox Grid.Column="0"
                                           Grid.Row="0"
                                           Header="Name"
                                           Text="{x:Bind ViewModel.SelectedItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <ComboBox Grid.Column="1"
                        Grid.Row="0"
                        HorizontalAlignment="Stretch"
                        Header="Side"
                        ItemsSource="{x:Bind ViewModel.GameDataService.Sides, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedItem.Side, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <engineTextBox:EngineTextBox Grid.Column="0"
                                           Grid.Row="1"
                                           Header="EditorSorting"
                                           Text="{x:Bind ViewModel.SelectedItem.EditorSorting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <engineTextBox:EngineTextBox Grid.Column="1"
                                           Grid.Row="1"
                                           Header="CommandSet"
                                           Text="{x:Bind ViewModel.SelectedItem.CommandSet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <engineTextBox:EngineTextBox Grid.Column="0"
                                           Grid.Row="2"
                                           Header="SelectPortrait"
                                           Text="{x:Bind ViewModel.SelectedItem.SelectPortrait, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <engineTextBox:EngineTextBox Grid.Column="1"
                                           Grid.Row="2"
                                           Header="ButtonImage"
                                           Text="{x:Bind ViewModel.SelectedItem.ButtonImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <!-- Production -->
              <engineTextBox:EngineTextBox Grid.Column="0"
                                           Grid.Row="3"
                                           Header="BuildCost"
                                           InputType="Integer"
                                           Text="{x:Bind ViewModel.SelectedItem.BuildCost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <engineTextBox:EngineTextBox Grid.Column="1"
                                           Grid.Row="3"
                                           Header="BuildTime"
                                           InputType="Double"
                                           Text="{x:Bind ViewModel.SelectedItem.BuildTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <engineTextBox:EngineTextBox Grid.Column="0"
                                           Grid.Row="4"
                                           Header="BuildCompletion"
                                           Text="{x:Bind ViewModel.SelectedItem.BuildCompletion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <engineTextBox:EngineTextBox Grid.Column="1"
                                           Grid.Row="4"
                                           Header="TransportSlotCount"
                                           Text="{x:Bind ViewModel.SelectedItem.TransportSlotCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

              <!-- Upgrade Cameos (read-only list for now) -->
              <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="5" Spacing="4">
                <TextBlock Text="Upgrade Cameos" FontWeight="SemiBold" />
                <ListView ItemsSource="{x:Bind ViewModel.SelectedItem.UpgradeCameos, Mode=OneWay}" />
              </StackPanel>
            </Grid>
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Stretch"
                        Spacing="12">
              <!-- Prerequisites (typed list: Object/Science) -->
              <StackPanel HorizontalAlignment="Stretch"
                          Spacing="4">
                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Prerequisites" FontWeight="SemiBold" />
                  <Button Grid.Column="1"
                          Content="Add"
                          Command="{x:Bind ViewModel.AddPrerequisiteCommand, Mode=OneWay}"
                          ToolTipService.ToolTip="Add prerequisite row" />
                </Grid>

                <ListView x:Name="PrereqList"
                          Tag="{x:Bind ViewModel, Mode=OneWay}"
                          ItemsSource="{x:Bind ViewModel.SelectedItem.PrereqEntries, Mode=OneWay}">
                  <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PrerequisiteSetModel">
                      <Grid ColumnSpacing="8"
                            Padding="0 10 0 10">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Type picker -->
                        <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                        <ComboBox Grid.Column="0"
                                  MinWidth="200"
                                  MaxWidth="200"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ItemsSource="{ui:EnumValues Type=enumerations:PrerequisiteType}"
                                  SelectedItem="{x:Bind PrerequisiteType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ComboBox Grid.Column="1"
                                  MinWidth="250"
                                  MaxWidth="250"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ItemsSource="{Binding PrerequisiteChoices}"
                                  SelectedItem="{Binding Prerequisite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                        <Button Grid.Column="2"
                                ToolTipService.ToolTip="Remove"
                                AutomationProperties.Name="Remove"
                                Command="{Binding ElementName=PrereqList, Path=Tag.RemovePrerequisiteCommand}"
                                CommandParameter="{Binding}"
                                Background="{StaticResource RedBrush}">
                          <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                        </Button>
                      </Grid>
                    </DataTemplate>
                  </ListView.ItemTemplate>
                </ListView>
              </StackPanel>

              <!-- KindOf flags (checkbox list) -->
              <ScrollView VerticalScrollBarVisibility="Auto"
                          MinHeight="400"
                          MaxHeight="400">
                <Border Padding="8 5 8 5"
                        CornerRadius="8"
                        Background="{StaticResource PrimaryBrush}">
                  <StackPanel Spacing="6">
                    <TextBlock Text="KindOf" FontWeight="SemiBold" />
                    <ListView x:Name="KindOfCheckboxList"
                              ItemsSource="{ui:EnumValues Type=enumerations:KindOf}"
                              SelectionMode="None">
                      <ListView.ItemTemplate>
                        <DataTemplate x:DataType="enumerations:KindOf">
                          <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                          <CheckBox Content="{x:Bind}"
                                    behaviors:CheckedListBehavior.Value="{Binding}"
                                    behaviors:CheckedListBehavior.ItemsSource="{Binding ElementName=KindOfCheckboxList, Path=DataContext.SelectedItem.KindOf}" />
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </StackPanel>
                </Border>
              </ScrollView>
            </StackPanel>
          </Grid>
        </enginePanel:EnginePanel>

        <!-- 2) Visuals (W3D) -->
        <enginePanel:EnginePanel Grid.Row="1"
                                 Title="Visuals (W3D)"
                                 Visibility="{x:Bind ViewModel.SelectedItem, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="6">
            <TextBlock Text="Draw entries, ConditionStates, TransitionStates, Model/Animations, Weapon bones &amp; FX hooks" />
          </StackPanel>
        </enginePanel:EnginePanel>

        <!-- 3) Armor & Health -->
        <!-- TODO - Add DamageFX-->
        <enginePanel:EnginePanel Grid.Row="2"
                                 Title="Armor &amp; Health"
                                 Visibility="{x:Bind ViewModel.SelectedItem, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="10">
            <!-- Body -->
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <engineTextBox:EngineTextBox Grid.Column="0"
                                           Header="MaxHealth"
                                           InputType="Double"
                                           Text="{x:Bind ViewModel.SelectedItem.MaxHealth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              <engineTextBox:EngineTextBox Grid.Column="1"
                                           Header="InitialHealth"
                                           InputType="Double"
                                           Text="{x:Bind ViewModel.SelectedItem.InitialHealth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!-- Armor Sets -->
            <StackPanel Spacing="6">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Armor Sets" FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Content="Add Set"
                        Command="{x:Bind ViewModel.AddArmorSetCommand}" />
              </Grid>

              <ListView x:Name="ArmorSetsList"
                        Tag="{x:Bind ViewModel, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.SelectedItem.ArmorSets, Mode=OneWay}">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="models:ArmorSetModel">
                    <Grid x:Name="ArmorSetRoot"
                          ColumnSpacing="8"
                          RowSpacing="15"
                          Padding="0 8 0 10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <ComboBox Grid.Column="0"
                                Header="Armor"
                                MinWidth="250"
                                MaxWidth="250"
                                ItemsSource="{Binding ElementName=ArmorSetsList, Path=Tag.ArmorSets}"
                                SelectedItem="{x:Bind Armor, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                      <!-- Conditions flags (checkbox list) -->
                      <Border Grid.Column="0"
                              Grid.Row="1"
                              Padding="8 5 8 5"
                              Background="{StaticResource PrimaryBrush}"
                              CornerRadius="8">
                        <StackPanel Spacing="6">
                          <TextBlock Text="Armor Conditions" FontWeight="SemiBold" />
                          <ListView x:Name="ArmorConditionsCheckboxList"
                                    ItemsSource="{ui:EnumValues Type=enumerations:ArmorConditions}"
                                    SelectionMode="None">
                            <ListView.ItemTemplate>
                              <DataTemplate x:DataType="enumerations:ArmorConditions">
                                <CheckBox Content="{x:Bind}"
                                          behaviors:CheckedListBehavior.Value="{Binding}"
                                          behaviors:CheckedListBehavior.ItemsSource="{Binding ElementName=ArmorConditionsCheckboxList, Path=DataContext.Conditions}" />
                              </DataTemplate>
                            </ListView.ItemTemplate>
                          </ListView>
                        </StackPanel>
                      </Border>

                      <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                      <Button Grid.Column="1"
                              Grid.Row="0"
                              Grid.RowSpan="3"
                              ToolTipService.ToolTip="Remove"
                              AutomationProperties.Name="Remove"
                              Command="{Binding ElementName=ArmorSetsList, Path=Tag.RemoveArmorSetCommand}"
                              CommandParameter="{Binding}"
                              Background="{StaticResource RedBrush}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>
          </StackPanel>
        </enginePanel:EnginePanel>

        <!-- 4) Weapons -->
        <enginePanel:EnginePanel Grid.Row="3"
                                 Title="Weapons"
                                 Visibility="{x:Bind ViewModel.SelectedItem , Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <StackPanel Spacing="10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Weapon Sets" FontWeight="SemiBold" />
              <Button Grid.Column="1"
                      Content="Add Set"
                      Command="{x:Bind ViewModel.AddWeaponSetCommand}" />
            </Grid>

            <ListView x:Name="WeaponSetsList"
                      Tag="{x:Bind ViewModel, Mode=OneWay}"
                      ItemsSource="{x:Bind ViewModel.SelectedItem.WeaponSets, Mode=OneWay}">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="weaponSet:WeaponSlotModel">
                  <Grid x:Name="WeaponSlotRoot" ColumnSpacing="6" RowSpacing="8" Padding="8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Conditions flags (checkbox list) -->
                    <Border Grid.Column="0"
                            Grid.Row="0"
                            Padding="8 5 8 5"
                            Background="{StaticResource PrimaryBrush}"
                            CornerRadius="8">
                      <StackPanel Spacing="6">
                        <TextBlock Text="Weapon Conditions" FontWeight="SemiBold" />
                        <ListView x:Name="WeaponConditionsCheckboxList"
                                  ItemsSource="{ui:EnumValues Type=enumerations:WeaponConditions}"
                                  SelectionMode="None">
                          <ListView.ItemTemplate>
                            <DataTemplate x:DataType="enumerations:WeaponConditions">
                              <CheckBox Content="{x:Bind}"
                                        behaviors:CheckedListBehavior.Value="{Binding}"
                                        behaviors:CheckedListBehavior.ItemsSource="{Binding ElementName=WeaponConditionsCheckboxList, Path=DataContext.Conditions}" />
                            </DataTemplate>
                          </ListView.ItemTemplate>
                        </ListView>
                      </StackPanel>
                    </Border>

                    <!-- Weapon List -->
                    <Border Grid.Column="0"
                            Grid.Row="1"
                            Padding="8 5 8 5"
                            Background="{StaticResource PrimaryBrush}"
                            CornerRadius="8">
                      <StackPanel Spacing="6">
                        <Grid HorizontalAlignment="Stretch"
                              ColumnSpacing="20">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                          </Grid.RowDefinitions>

                          <TextBlock Text="Weapons" FontWeight="SemiBold" />

                          <ComboBox Grid.Column="0"
                                    Grid.Row="1"
                                    x:Name="WeaponSlotChoice"
                                    VerticalAlignment="Bottom"
                                    Header="Slot"
                                    MinWidth="160"
                                    MaxWidth="160"
                                    ItemsSource="{ui:EnumValues Type=enumerations:WeaponSlot}" />

                          <Button Grid.Column="1"
                                  Grid.Row="1"
                                  AutomationProperties.Name="Remove"
                                  VerticalAlignment="Bottom"
                                  Content="Add"
                                  Command="{x:Bind AddWeaponCommand}"
                                  CommandParameter="{Binding ElementName=WeaponSlotChoice, Path=SelectedItem, Mode=OneWay}"
                                  ToolTipService.ToolTip="Weapon" />
                        </Grid>
                        <ListView x:Name="WeaponList"
                                  Tag="{Binding ElementName=WeaponSetsList, Path=SelectedItem}"
                                  ItemsSource="{x:Bind Weapons, Mode=OneWay}">
                          <ListView.ItemTemplate>
                            <DataTemplate x:DataType="weaponSet:WeaponModel">
                              <Grid ColumnSpacing="8"
                                    Padding="0 10 0 10">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind WeaponSlot}"
                                           FontWeight="SemiBold" />

                                <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ElementName=WeaponSetsList, Path=Tag.GameDataService.GameWeapons}"
                                          SelectedItem="{x:Bind Weapon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                <Button Grid.Column="2"
                                        ToolTipService.ToolTip="Remove"
                                        AutomationProperties.Name="Remove"
                                        Command="{Binding ElementName=WeaponList, Path=Tag.RemoveWeaponCommand}"
                                        CommandParameter="{Binding}"
                                        Background="{StaticResource RedBrush}">
                                  <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                                </Button>
                              </Grid>
                            </DataTemplate>
                          </ListView.ItemTemplate>
                        </ListView>
                      </StackPanel>
                    </Border>

                    <!-- AutoChooseSources sub-list -->
                    <Border Grid.Column="0"
                            Grid.Row="2"
                            Padding="8 5 8 5"
                            Background="{StaticResource PrimaryBrush}"
                            CornerRadius="8">
                      <StackPanel Spacing="6">
                        <Grid HorizontalAlignment="Stretch"
                              ColumnSpacing="20">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                          </Grid.RowDefinitions>

                          <TextBlock Text="Auto Choose Sources" FontWeight="SemiBold" />

                          <ComboBox Grid.Column="0"
                                    Grid.Row="1"
                                    x:Name="AutoChooseSourcesSlot"
                                    VerticalAlignment="Bottom"
                                    Header="Slot"
                                    MinWidth="160"
                                    MaxWidth="160"
                                    ItemsSource="{ui:EnumValues Type=enumerations:WeaponSlot}" />

                          <Button Grid.Column="1"
                                  Grid.Row="1"
                                  AutomationProperties.Name="Add"
                                  VerticalAlignment="Bottom"
                                  Content="Add"
                                  Command="{x:Bind AddAutoChooseSourcesCommand}"
                                  CommandParameter="{Binding ElementName=AutoChooseSourcesSlot, Path=SelectedItem, Mode=OneWay}"
                                  ToolTipService.ToolTip="Auto Choose Sources" />
                        </Grid>
                        <ListView x:Name="AutoChooseSourcesList"
                                  Tag="{Binding ElementName=WeaponSetsList, Path=SelectedItem}"
                                  ItemsSource="{x:Bind AutoChooseSources, Mode=OneWay}">
                          <ListView.ItemTemplate>
                            <DataTemplate x:DataType="weaponSet:WeaponAutoChooseSourceModel">
                              <Grid ColumnSpacing="8"
                                    Padding="0 10 0 10">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind WeaponSlot}"
                                           FontWeight="SemiBold" />

                                <ListView Grid.Column="1"
                                          x:Name="AutoChooseSourceSelector"
                                          ItemsSource="{ui:EnumValues Type=enumerations:AutoChooseSources}"
                                          SelectionMode="None">
                                  <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="enumerations:AutoChooseSources">
                                      <CheckBox Content="{x:Bind}"
                                                behaviors:CheckedListBehavior.Value="{Binding}"
                                                behaviors:CheckedListBehavior.ItemsSource="{Binding ElementName=AutoChooseSourceSelector, Path=DataContext.SelectedItem.AutoChooseSources}" />
                                    </DataTemplate>
                                  </ListView.ItemTemplate>
                                </ListView>

                                <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                <Button Grid.Column="2"
                                        ToolTipService.ToolTip="Remove"
                                        AutomationProperties.Name="Remove"
                                        Command="{Binding ElementName=AutoChooseSourcesList, Path=Tag.RemoveAutoChooseSourcesCommand}"
                                        CommandParameter="{Binding}"
                                        Background="{StaticResource RedBrush}">
                                  <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                                </Button>
                              </Grid>
                            </DataTemplate>
                          </ListView.ItemTemplate>
                        </ListView>
                      </StackPanel>
                    </Border>

                    <!-- Weapon lock across sets (nullable) -->
                    <ComboBox Grid.Column="0"
                              Grid.Row="3"
                              Header="WeaponLockSharedAcrossSets"
                              ItemsSource="{ui:EnumValues Type=enumerations:WeaponLockSharedAcrossSets}"
                              SelectedItem="{x:Bind WeaponLockSharedAcrossSets, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              MinWidth="250"
                              MaxWidth="250" />

                    <!-- Remove set button -->
                    <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                    <Button Grid.Column="1"
                            Grid.Row="0"
                            Grid.RowSpan="4"
                            ToolTipService.ToolTip="Remove"
                            AutomationProperties.Name="Remove"
                            Command="{Binding ElementName=WeaponSetsList, Path=Tag.RemoveWeaponSetCommand}"
                            CommandParameter="{Binding}"
                            Background="{StaticResource RedBrush}">
                      <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" />
                    </Button>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </StackPanel>
        </enginePanel:EnginePanel>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
