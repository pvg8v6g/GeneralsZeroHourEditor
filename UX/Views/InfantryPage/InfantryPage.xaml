<Page x:Class="GeneralsZeroHourEditor.UX.Views.InfantryPage.InfantryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:behaviors="using:GeneralsZeroHourEditor.Behaviors"
      mc:Ignorable="d"
      behaviors:LoadedBehavior.LoadedCommand="{x:Bind ViewModel.LoadedCommand}">
  <Grid Margin="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="10" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left: Infantry list -->
    <Border Grid.Column="0"
            Background="{StaticResource SecondaryBrush}"
            Padding="8"
            CornerRadius="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="Infantry"
                   FontWeight="Bold"
                   Foreground="{StaticResource WhiteBrush}" />
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Model.Infantry}"
                  SelectedItem="{Binding Model.SelectedInfantry}"
                  Margin="0,6,0,0">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
          </ListView.ItemContainerStyle>
        </ListView>
      </Grid>
    </Border>

    <!-- Right: Modules palette from schema -->
    <ScrollViewer Grid.Column="2"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <ItemsControl ItemsSource="{Binding Model.Modules}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Expander Header="{Binding Name}"
                        IsExpanded="False"
                        Margin="0,0,0,8">
                <StackPanel>
                  <TextBlock Text="Fields" FontWeight="SemiBold" />
                  <ItemsControl ItemsSource="{Binding Fields}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <ItemsControl ItemsSource="{Binding SubBlocks}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Margin="0,6,0,0">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                          <ItemsControl ItemsSource="{Binding Fields}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding}" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Expander>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
