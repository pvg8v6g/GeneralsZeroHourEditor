<Page x:Class="GeneralsZeroHourEditor.UX.Views.WeaponPage.WeaponPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:behaviors="using:GeneralsZeroHourEditor.Behaviors"
      xmlns:models="using:GeneralsZeroHourEditor.Models"
      xmlns:enginePanel="using:GeneralsZeroHourEditor.UX.Components.EnginePanel"
      xmlns:engineTextBox="using:GeneralsZeroHourEditor.UX.Components.EngineTextBox"
      xmlns:enumerations="using:GeneralsZeroHourEditor.Enumerations"
      xmlns:ui="using:CommunityToolkit.WinUI"
      mc:Ignorable="d"
      behaviors:LoadedBehavior.LoadedCommand="{x:Bind ViewModel.LoadedCommand}">
  <Grid ColumnSpacing="10" Padding="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="350" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left: Weapons list -->
    <Border Grid.Column="0"
            Background="{StaticResource SecondaryBrush}"
            Padding="8"
            CornerRadius="6">
      <Grid RowSpacing="6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="Weapons"
                   FontWeight="Bold"
                   Foreground="{StaticResource WhiteBrush}" />
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Weapons, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  SelectionMode="Single">
          <ListView.ContextFlyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="New Weapon" Command="{x:Bind ViewModel.NewWeaponCommand, Mode=OneWay}" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="Copy" Command="{x:Bind ViewModel.CopyWeaponCommand, Mode=OneWay}" />
              <MenuFlyoutItem Text="Paste" Command="{x:Bind ViewModel.PasteWeaponCommand, Mode=OneWay}" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="Delete" Command="{x:Bind ViewModel.DeleteWeaponCommand, Mode=OneWay}" />
            </MenuFlyout>
          </ListView.ContextFlyout>
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="models:Weapon.WeaponDefinition">
              <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

    <!-- Right: Weapon details -->
    <ScrollViewer Grid.Column="1"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowSpacing="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <enginePanel:EnginePanel Grid.Row="0"
                                 Title="Weapon Details"
                                 Visibility="{x:Bind ViewModel.SelectedItem, Converter={StaticResource NullToCollapsedConverter}, Mode=OneWay}">
          <Grid RowSpacing="10" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <engineTextBox:EngineTextBox Grid.Column="0" Grid.Row="0"
                                         Header="Name"
                                         Text="{x:Bind ViewModel.SelectedItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1" Grid.Row="0"
                                         Header="PrimaryDamage"
                                         Text="{x:Bind ViewModel.SelectedItem.PrimaryDamage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="2" Grid.Row="0"
                                         Header="PrimaryDamageRadius"
                                         Text="{x:Bind ViewModel.SelectedItem.PrimaryDamageRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0" Grid.Row="1"
                                         Header="AttackRange"
                                         Text="{x:Bind ViewModel.SelectedItem.AttackRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1" Grid.Row="1"
                                         Header="MinimumAttackRange"
                                         Text="{x:Bind ViewModel.SelectedItem.MinimumAttackRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="2" Grid.Row="1"
                                         Header="DelayBetweenShots"
                                         Text="{x:Bind ViewModel.SelectedItem.DelayBetweenShots, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0" Grid.Row="2"
                                         Header="PreAttackDelay"
                                         Text="{x:Bind ViewModel.SelectedItem.PreAttackDelay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="1" Grid.Row="2"
                                         Header="ProjectileObject"
                                         Text="{x:Bind ViewModel.SelectedItem.ProjectileObject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="2" Grid.Row="2"
                                         Header="FireFX"
                                         Visibility="Collapsed" />

            <ComboBox Grid.Column="2" Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      Header="FireFX"
                      ItemsSource="{x:Bind ViewModel.GameDataService.FXLists, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedItem.FireFX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Column="0" Grid.Row="3"
                      HorizontalAlignment="Stretch"
                      Header="DamageType"
                      ItemsSource="{ui:EnumValues Type=enumerations:DamageType}"
                      SelectedItem="{x:Bind ViewModel.SelectedItem.DamageType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Column="1" Grid.Row="3"
                      HorizontalAlignment="Stretch"
                      Header="DeathType"
                      ItemsSource="{ui:EnumValues Type=enumerations:DeathType}"
                      SelectedItem="{x:Bind ViewModel.SelectedItem.DeathType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="2" Grid.Row="3"
                                         Header="ScatterRadius"
                                         Text="{x:Bind ViewModel.SelectedItem.ScatterRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="0" Grid.Row="4"
                                         Header="ProjectileDetonationOCL"
                                         Text="{x:Bind ViewModel.SelectedItem.ProjectileDetonationOCL, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Column="1" Grid.Row="4"
                      HorizontalAlignment="Stretch"
                      Header="ProjectileCollidesWith"
                      ItemsSource="{ui:EnumValues Type=enumerations:ProjectileCollidesWith}"
                      SelectedItem="{x:Bind ViewModel.SelectedItem.ProjectileCollidesWith, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <engineTextBox:EngineTextBox Grid.Column="2" Grid.Row="4"
                                         Header="AcceptableAimDelta"
                                         Text="{x:Bind ViewModel.SelectedItem.AcceptableAimDelta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </Grid>
        </enginePanel:EnginePanel>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
