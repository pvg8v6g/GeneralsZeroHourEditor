<Page x:Class="GeneralsZeroHourEditor.UX.Views.VehiclePage.VehiclePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:behaviors="using:GeneralsZeroHourEditor.Behaviors"
      xmlns:models="using:GeneralsZeroHourEditor.Models"
      mc:Ignorable="d"
      behaviors:LoadedBehavior.LoadedCommand="{x:Bind ViewModel.LoadedCommand}">
  <Grid ColumnSpacing="10" Padding="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="350" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left: Vehicle list -->
    <Border Grid.Column="0"
            Background="{StaticResource SecondaryBrush}"
            Padding="8"
            CornerRadius="6">
      <Grid RowSpacing="6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="Vehicle"
                   FontWeight="Bold"
                   Foreground="{StaticResource WhiteBrush}" />
        <TreeView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Model.GameObjectGroups, Mode=OneWay}"
                  behaviors:TreeViewBehavior.ItemInvokedCommand="{x:Bind ViewModel.ItemInvokedCommand}">
          <TreeView.ItemTemplate>
            <DataTemplate x:DataType="models:GameObjectNodeModel">
              <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}">
                <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
              </TreeViewItem>
            </DataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
      </Grid>
    </Border>

    <ScrollViewer Grid.Column="1"
                  VerticalScrollBarVisibility="Auto" />
  </Grid>
</Page>
